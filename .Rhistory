df_2000_final_clean <- df_2000_final %>%
filter(gentrifiable_num_2000 == 1) %>%
select(-medinc_2000, -gentrifiable_num_2000, -gentrifiable_2000, -gentrified)
df_2010_final_clean <- df_2010_final %>%
filter(gentrifiable_num_2010 == 1) %>%
